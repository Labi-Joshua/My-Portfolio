---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 py-5 px-6 bg-white/90 backdrop-blur-sm">
  <nav class="flex items-center justify-center gap-10 text-sm">
    <a
      href="/"
      class={currentPath === '/' ? 'text-neutral-900 font-medium' : 'text-neutral-400 hover:text-neutral-700 transition-colors'}
    >
      Home
    </a>
    <a
      href="/articles"
      class={currentPath.startsWith('/articles') ? 'text-neutral-900 font-medium' : 'text-neutral-400 hover:text-neutral-700 transition-colors'}
    >
      Articles
    </a>
    <a
      href="/about"
      class={currentPath === '/about' ? 'text-neutral-900 font-medium' : 'text-neutral-400 hover:text-neutral-700 transition-colors'}
    >
      About
    </a>
  </nav>
</header>
