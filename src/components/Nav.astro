---
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 py-5 px-6 backdrop-blur-xl" style="background: rgba(255,255,255,0.15); border-bottom: 1px solid rgba(255,255,255,0.2);">
  <nav class="flex items-center justify-center gap-10 text-sm">
    <a
      href="/"
      class={currentPath === '/' ? 'font-medium' : 'text-neutral-700 hover:text-neutral-900 transition-colors'}
      style={currentPath === '/' ? 'color: #51782B;' : ''}
    >
      Home
    </a>
    <a
      href="/articles"
      class={currentPath.startsWith('/articles') ? 'font-medium' : 'text-neutral-700 hover:text-neutral-900 transition-colors'}
      style={currentPath.startsWith('/articles') ? 'color: #51782B;' : ''}
    >
      Articles
    </a>
    <a
      href="/about"
      class={currentPath === '/about' ? 'font-medium' : 'text-neutral-700 hover:text-neutral-900 transition-colors'}
      style={currentPath === '/about' ? 'color: #51782B;' : ''}
    >
      About
    </a>
  </nav>
</header>
