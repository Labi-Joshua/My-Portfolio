---
interface Props {
  slug: string;
  title: string;
  description?: string;
  tags: string;
  coverImage: string;
  coverAlt: string;
  index: number;
}

const { slug, title, description, tags, coverImage, coverAlt, index } = Astro.props;
---

<a
  href={`/work/${slug}`}
  class="group card-hover flex flex-col md:flex-row rounded-3xl overflow-hidden h-fit w-full"
>
  <!-- Text content -->
  <div class="p-8 md:w-1/2 md:shrink-0 md:p-10 flex flex-col">
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-green inline-block shrink-0"></span>
      <span class="text-xs text-neutral-500 tracking-wide">Case Study</span>
    </div>
    <div class="flex flex-col justify-center mt-16 md:mt-0 md:flex-1">
      <h3 class="font-serif text-[34px] font-normal leading-tight text-neutral-900 whitespace-pre-line">{title}</h3>
      {description && <p class="text-sm text-neutral-500 leading-relaxed mt-3 max-w-xs">{description}</p>}
    </div>
  </div>

  <!-- Image: mobile only (bottom, ExperimentCard style) -->
  <div class="md:hidden mx-3 mb-3 mt-4 rounded-2xl overflow-hidden h-[214px]">
    <img
      src={coverImage}
      alt={coverAlt}
      class="w-full h-full object-cover object-top"
      loading={index === 0 ? 'eager' : 'lazy'}
    />
  </div>

  <!-- Image: tablet and above (right side, responsive) -->
  <div class="hidden md:block shrink-0" style="width: 50%; padding: 12px 12px 12px 0;">
    <div style="width: 100%; aspect-ratio: 1 / 1; overflow: hidden; border-radius: 16px;">
      <img
        src={coverImage}
        alt={coverAlt}
        class="w-full h-full object-cover object-top"
        loading={index === 0 ? 'eager' : 'lazy'}
      />
    </div>
  </div>
</a>
