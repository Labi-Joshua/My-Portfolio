---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FooterCTA from '../components/FooterCTA.astro';
import { getSiteSettings } from '../data/settings';

interface Props {
  title: string;
  description?: string;
  showCTA?: boolean;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  socialLinks?: string[];
}

const {
  title,
  description = 'Labi Joshua is a Product Designer who builds systems to solve complex problems.',
  showCTA = true,
  ogImage,
  ogImageAlt,
  ogType = 'website',
  socialLinks = [],
} = Astro.props;

const settings = await getSiteSettings();

const siteUrl = 'https://labijoshua.com';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const socialImage = ogImage || `${siteUrl}/og-default.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#person`,
      name: 'Labi Joshua',
      alternateName: 'Joshua Owolabi',
      url: siteUrl,
      jobTitle: 'Product Designer',
      description: 'Product Designer who builds systems to solve complex problems.',
      image: socialImage,
      sameAs: [
        ...socialLinks,
        settings.mediumUrl,
        settings.twitterUrl,
        settings.instagramUrl,
        settings.linkedinUrl,
      ].filter(Boolean),
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: 'Labi Joshua',
      url: siteUrl,
      author: { '@id': `${siteUrl}/#person` },
    },
    {
      '@type': 'WebPage',
      url: canonical,
      name: title,
      description,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#person` },
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.ico.png" />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#51782B" />

    <!-- Font preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Labi Joshua" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt || description} />
    <meta property="og:site_name" content="Labi Joshua" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={ogImageAlt || description} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <!-- Per-page head slot (additional structured data etc.) -->
    <slot name="head" />
  </head>
  <body class="bg-white text-neutral-900 font-sans antialiased min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    {showCTA && <FooterCTA />}
    <Footer
      mediumUrl={settings.mediumUrl}
      twitterUrl={settings.twitterUrl}
      instagramUrl={settings.instagramUrl}
      linkedinUrl={settings.linkedinUrl}
    />
  </body>

  <script is:inline>
    (function () {
      var s = document.createElement('style');
      s.textContent = '@keyframes cursor-spin{to{transform:translate(-50%,-50%) rotate(360deg)}}@keyframes cursor-pulse{0%,100%{width:18px;height:18px}50%{width:30px;height:30px}}';
      document.head.appendChild(s);

      var wrap = document.createElement('div');
      wrap.style.cssText = 'position:fixed;pointer-events:none;z-index:9999;width:0;height:0;opacity:0;transition:opacity 0.2s;';

      var ring = document.createElement('div');
      ring.style.cssText = 'position:absolute;width:22px;height:22px;border-radius:50%;border:1.5px dashed #51782B;transform:translate(-50%,-50%);animation:cursor-spin 2.5s linear infinite;transition:border-color 0.2s ease;';

      var dot = document.createElement('div');
      dot.style.cssText = 'position:absolute;width:5px;height:5px;border-radius:50%;background:#51782B;transform:translate(-50%,-50%);transition:background 0.2s ease;';

      wrap.appendChild(ring);
      wrap.appendChild(dot);
      document.body.appendChild(wrap);

      var label = document.createElement('div');
      label.style.cssText = 'position:fixed;pointer-events:none;z-index:9998;font-family:"Instrument Sans",sans-serif;font-size:14px;color:#1a1a1a;background:rgba(255,255,255,0.85);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);padding:5px 13px;border-radius:100px;white-space:nowrap;opacity:0;transform:translateY(6px);transition:opacity 0.25s ease,transform 0.25s ease;top:0;left:0;';
      document.body.appendChild(label);

      function getBgLuminance(x, y) {
        var el = document.elementFromPoint(x, y);
        while (el && el !== document.body) {
          var bg = window.getComputedStyle(el).backgroundColor;
          if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
            var m = bg.match(/\d+/g);
            if (m) return 0.2126 * m[0] + 0.7152 * m[1] + 0.0722 * m[2];
          }
          el = el.parentElement;
        }
        return 255;
      }

      function updateCursorColor(x, y) {
        var lum = getBgLuminance(x, y);
        var color = lum < 140 ? '#ffffff' : '#51782B';
        ring.style.borderColor = color;
        dot.style.background = color;
      }

      var lx = 0, ly = 0, tx = 0, ty = 0, rafId = null, onImg = false, pulsing = false;

      function lerp(a, b, t) { return a + (b - a) * t; }
      function tick() {
        lx = lerp(lx, tx, 0.12);
        ly = lerp(ly, ty, 0.12);
        label.style.left = lx + 'px';
        label.style.top  = ly + 'px';
        rafId = requestAnimationFrame(tick);
      }

      function isInteractive(el) {
        while (el && el !== document.body) {
          var tag = el.tagName;
          if (tag === 'IMG' || tag === 'A' || tag === 'BUTTON' || el.getAttribute('role') === 'button') return true;
          el = el.parentElement;
        }
        return false;
      }

      function setPulse(on) {
        if (on === pulsing) return;
        pulsing = on;
        ring.style.animation = on
          ? 'cursor-spin 2.5s linear infinite,cursor-pulse 1.4s ease-in-out infinite'
          : 'cursor-spin 2.5s linear infinite';
      }

      function showLabel(img) {
        var text = img.dataset.cursorLabel || img.alt || '';
        label.textContent = text;
        label.style.opacity = text ? '1' : '0';
        label.style.transform = text ? 'translateY(0)' : 'translateY(6px)';
        if (text && !rafId) rafId = requestAnimationFrame(tick);
      }

      function hideLabel() {
        label.style.opacity = '0';
        label.style.transform = 'translateY(6px)';
        if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
      }

      document.addEventListener('mousemove', function (e) {
        wrap.style.left = e.clientX + 'px';
        wrap.style.top  = e.clientY + 'px';
        tx = e.clientX + 20;
        ty = e.clientY + 20;

        updateCursorColor(e.clientX, e.clientY);

        var el = e.target;
        setPulse(isInteractive(el));

        if (el.tagName === 'IMG') {
          if (!onImg) { onImg = true; showLabel(el); }
        } else if (onImg) {
          onImg = false; hideLabel();
        }
      });

      document.addEventListener('mouseenter', function () { wrap.style.opacity = '1'; });
      document.addEventListener('mouseleave', function () { wrap.style.opacity = '0'; hideLabel(); onImg = false; setPulse(false); });
    })();
  </script>
</html>
