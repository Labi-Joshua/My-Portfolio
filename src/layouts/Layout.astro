---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FooterCTA from '../components/FooterCTA.astro';
import { getSiteSettings } from '../data/settings';

interface Props {
  title: string;
  description?: string;
  showCTA?: boolean;
  ogImage?: string;
  ogType?: 'website' | 'article';
  socialLinks?: string[];
}

const {
  title,
  description = 'Labi Joshua is a Product Designer who builds systems to solve complex problems.',
  showCTA = true,
  ogImage,
  ogType = 'website',
  socialLinks = [],
} = Astro.props;

const settings = await getSiteSettings();

const siteUrl = 'https://labijoshua.com';
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const socialImage = ogImage || `${siteUrl}/og-default.png`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#person`,
      name: 'Labi Joshua',
      alternateName: 'Joshua Owolabi',
      url: siteUrl,
      jobTitle: 'Product Designer',
      description: 'Product Designer who builds systems to solve complex problems.',
      image: socialImage,
      sameAs: [
        ...socialLinks,
        settings.mediumUrl,
        settings.twitterUrl,
        settings.instagramUrl,
        settings.linkedinUrl,
      ].filter(Boolean),
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: 'Labi Joshua',
      url: siteUrl,
      author: { '@id': `${siteUrl}/#person` },
    },
    {
      '@type': 'WebPage',
      url: canonical,
      name: title,
      description,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': `${siteUrl}/#person` },
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.ico.png" />
    <link rel="canonical" href={canonical} />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Labi Joshua" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Labi Joshua" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="bg-white text-neutral-900 font-sans antialiased min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    {showCTA && <FooterCTA />}
    <Footer
      mediumUrl={settings.mediumUrl}
      twitterUrl={settings.twitterUrl}
      instagramUrl={settings.instagramUrl}
      linkedinUrl={settings.linkedinUrl}
    />
  </body>
</html>
