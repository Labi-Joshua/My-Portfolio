---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import ExperimentCard from '../components/ExperimentCard.astro';
import { caseStudies, experiments } from '../data/projects';

const yearRange = `${Math.min(...caseStudies.map(p => parseInt(p.year)))} — ${new Date().getFullYear() + 1}`;
---

<Layout title="Labi Joshua — Product Designer">

  <Hero />

  <!-- Selected Works -->
  <section id="work" class="px-6 pb-16 max-w-[1116px] mx-auto" style="margin-bottom: 64px;">

    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-2 text-sm text-neutral-500">
        <!-- Folder icon -->
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1.5 3.5C1.5 2.948 1.948 2.5 2.5 2.5H6.086a1 1 0 0 1 .707.293L7.5 3.5H13.5C14.052 3.5 14.5 3.948 14.5 4.5v8c0 .552-.448 1-1 1h-11c-.552 0-1-.448-1-1v-9z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Selected Works
      </div>
      <span class="text-sm text-neutral-400">
        {caseStudies.length} case {caseStudies.length === 1 ? 'study' : 'studies'} · {yearRange}
      </span>
    </div>

    <div class="flex flex-col gap-5 items-start">
      {caseStudies.map((project, i) => (
        <CaseStudyCard
          slug={project.slug}
          title={project.title}
          tags={project.tags}
          coverImage={project.coverImage}
          coverAlt={project.coverAlt}
          index={i}
        />
      ))}
    </div>
  </section>

  <!-- Experimental Work -->
  <section class="px-6 pb-0 max-w-[1100px] mx-auto">

    <div class="flex items-start justify-between gap-6 mb-10">
      <div class="flex flex-col gap-4">
        <span class="text-xs border border-dashed border-neutral-300 bg-neutral-100 rounded-full px-3.5 py-1 inline-block w-fit tracking-wide" style="color: rgba(0, 0, 0, 0.5);">
          Experiments
        </span>
        <h2 class="font-serif text-4xl md:text-5xl leading-[1.1] tracking-tight text-neutral-900">
          <em class="not-italic" style="color: #51782B;">Tools and templates</em> i built<br class="hidden sm:block" /> between breaks.
        </h2>
      </div>
      <span class="text-sm text-neutral-400 shrink-0 pt-1 hidden md:block">Mid-night escapades</span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 items-stretch">
      {experiments.map(exp => (
        <ExperimentCard
          category={exp.category}
          title={exp.title}
          description={exp.description}
          image={exp.image}
          imageAlt={exp.imageAlt}
          link={exp.link}
        />
      ))}
    </div>
  </section>

</Layout>
