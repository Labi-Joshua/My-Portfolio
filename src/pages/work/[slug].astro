---
import Layout from '../../layouts/Layout.astro';
import { getCaseStudies } from '../../data/projects';

const { slug } = Astro.params;
const caseStudies = await getCaseStudies();
const project = caseStudies.find(p => p.slug === slug);

if (!project) return Astro.redirect('/404');
---

<Layout
  title={`${project.title.replace('\n', ' ')} — Joshua Owolabi`}
  description={project.tags}
  ogImage={project.coverImage}
  ogType="website"
>

  <!-- Product preview hero — bleeds under sticky nav -->
  {project.previewImages?.length > 0 && (
    <div id="preview-hero" class="w-full aspect-[16/7] overflow-hidden bg-card" style="margin-top: -57px;">
      <img
        id="preview-hero-img"
        src={project.previewImages[0].src}
        alt={project.previewImages[0].alt}
        class="w-full h-full object-cover"
        style="transform: scale(1.08); transition: transform 0.08s ease-out; will-change: transform;"
        loading="eager"
      />
    </div>
  )}

  <script is:inline>
    (function () {
      const hero = document.getElementById('preview-hero');
      const img  = document.getElementById('preview-hero-img');
      if (!hero || !img) return;

      /* Inject spin keyframe */
      const styleEl = document.createElement('style');
      styleEl.textContent = '@keyframes cursor-spin{to{transform:translate(-50%,-50%) rotate(360deg)}}';
      document.head.appendChild(styleEl);

      /* Cursor wrapper — zero-size anchor point */
      const wrap = document.createElement('div');
      wrap.style.cssText = 'position:fixed;pointer-events:none;z-index:9999;width:0;height:0;opacity:0;transition:opacity 0.2s;';

      /* Rotating dashed ring */
      const ring = document.createElement('div');
      ring.style.cssText = [
        'position:absolute',
        'width:22px','height:22px',
        'border-radius:50%',
        'border:1.5px dashed #51782B',
        'transform:translate(-50%,-50%) rotate(0deg)',
        'animation:cursor-spin 2.5s linear infinite',
        'transition:border-color 0.12s ease',
      ].join(';');

      /* Small filled dot */
      const dot = document.createElement('div');
      dot.style.cssText = [
        'position:absolute',
        'width:5px','height:5px',
        'border-radius:50%',
        'background:#51782B',
        'transform:translate(-50%,-50%)',
        'transition:background 0.12s ease',
      ].join(';');

      wrap.appendChild(ring);
      wrap.appendChild(dot);
      document.body.appendChild(wrap);

      /* Canvas for pixel colour sampling */
      var canvas = document.createElement('canvas');
      var ctx = canvas.getContext('2d');
      var canvasReady = false;

      function initCanvas() {
        try {
          canvas.width  = 120;
          canvas.height = Math.round(120 * img.naturalHeight / img.naturalWidth) || 68;
          ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
          canvasReady = true;
        } catch(e) { canvasReady = false; }
      }

      if (img.complete && img.naturalWidth) { initCanvas(); }
      else { img.addEventListener('load', initCanvas); }

      function sampleColor(e, rect) {
        if (!canvasReady) return null;
        try {
          var x = Math.floor((e.clientX - rect.left) / rect.width  * canvas.width);
          var y = Math.floor((e.clientY - rect.top)  / rect.height * canvas.height);
          var px = ctx.getImageData(Math.max(0,x), Math.max(0,y), 1, 1).data;
          return 'rgb('+px[0]+','+px[1]+','+px[2]+')';
        } catch(e) { return null; }
      }

      hero.style.cursor = 'none';

      hero.addEventListener('mouseenter', function () {
        wrap.style.opacity = '1';
      });

      hero.addEventListener('mousemove', function (e) {
        wrap.style.left = e.clientX + 'px';
        wrap.style.top  = e.clientY + 'px';

        var rect  = hero.getBoundingClientRect();
        var color = sampleColor(e, rect);
        if (color) {
          ring.style.borderColor = color;
          dot.style.background   = color;
        }

        var x = (e.clientX - rect.left) / rect.width  - 0.5;
        var y = (e.clientY - rect.top)  / rect.height - 0.5;
        img.style.transform = 'scale(1.08) translate('+(x*18)+'px,'+(y*10)+'px)';
      });

      hero.addEventListener('mouseleave', function () {
        wrap.style.opacity = '0';
        img.style.transition = 'transform 0.4s ease-out';
        img.style.transform  = 'scale(1.08) translate(0px,0px)';
        setTimeout(function () { img.style.transition = 'transform 0.08s ease-out'; }, 400);
      });
    })();
  </script>

  <!-- Go back -->
  <div class="sticky top-[57px] z-40 bg-white/90 backdrop-blur-sm">
  <div class="px-6 py-4 max-w-[1100px] mx-auto">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-neutral-500 hover:text-neutral-900 transition-colors"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M12 7H2M2 7L6 3M2 7L6 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Go Back
    </a>
  </div>
  </div>

  <!-- Two-column layout -->
  <div class="px-6 pb-20 max-w-[1100px] mx-auto grid grid-cols-1 lg:grid-cols-[348px_1fr] gap-10 lg:gap-16 items-start">

    <!-- Left sidebar -->
    <aside class="lg:sticky lg:top-[116px] flex flex-col gap-6">

      <!-- Green info card -->
      <div class="bg-green rounded-2xl p-6 text-white">
        <h2 class="font-serif text-2xl font-normal leading-snug whitespace-pre-line" style="color: #F3F5F0;">{project.title}</h2>
        {project.description && <p class="text-sm text-white/75 mt-2 leading-relaxed">{project.description}</p>}
        {project.websiteUrl && (
          <a
            href={project.websiteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-5 flex items-center justify-center gap-2 rounded-full px-4 py-3 text-sm font-medium w-full transition-opacity hover:opacity-90"
            style="background-color: #F7F7F7; color: #3D5A20;"
          >
            Visit Website
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 10L10 2M10 2H5M10 2V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        )}
      </div>

      <!-- Metadata -->
      <div class="flex flex-col gap-5 text-sm">
        <div>
          <p class="text-xs text-neutral-400 uppercase tracking-widest mb-2">Role</p>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green shrink-0"></span>
            <span class="text-neutral-700">{project.role}</span>
          </div>
        </div>

        {project.technicalSpecs?.length > 0 && (
          <div>
            <p class="text-xs text-neutral-400 uppercase tracking-widest mb-2">Technical Specs</p>
            <div class="flex flex-col gap-1.5">
              {project.technicalSpecs.map(spec => (
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-green shrink-0"></span>
                  <span class="text-neutral-700">{spec}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <div>
          <p class="text-xs text-neutral-400 uppercase tracking-widest mb-2">Status</p>
          <span class="text-neutral-900 font-medium">{project.status}</span>
        </div>
      </div>
    </aside>

    <!-- Right content -->
    <div class="flex flex-col gap-14">
      {project.sections?.map((section) => (
        <div class="flex flex-col gap-5">
          <h3 class="text-2xl font-serif font-medium text-neutral-900">{section.heading}</h3>
          <p class="text-neutral-600 leading-relaxed text-base">{section.body}</p>

          {section.images && section.images.length > 0 && (
            <div class="flex flex-col gap-4 mt-2">
              {section.images.map(img => (
                <figure class="rounded-2xl overflow-hidden bg-card">
                  <img
                    src={img.src}
                    alt={img.alt}
                    class="w-full"
                    loading="lazy"
                  />
                  {img.caption && (
                    <figcaption class="text-xs text-neutral-400 text-center py-3 px-4">
                      {img.caption}
                    </figcaption>
                  )}
                </figure>
              ))}
            </div>
          )}

          {/* Testimonial card — injected after "The Solution" section */}
          {project.testimonial && section.showQuoteAfter && (
            <div class="bg-green rounded-2xl p-8 text-white mt-4">
              <p class="text-base leading-relaxed font-medium italic">{project.testimonial.quote}</p>
              <div class="mt-6 flex items-center justify-between">
                <div>
                  <p class="text-sm font-semibold">{project.testimonial.author}</p>
                  <p class="text-xs text-white/70 mt-0.5">{project.testimonial.authorRole}</p>
                </div>
                <span class="text-xs text-white/50">{project.testimonial.company}</span>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

  </div>

</Layout>
