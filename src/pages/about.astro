---
import Layout from '../layouts/Layout.astro';
import { getAboutPage } from '../data/about';

const about = await getAboutPage();

const profilePhoto    = about.profilePhoto    || '/images/about-profile.jpg';
const profilePhotoAlt = about.profilePhotoAlt || 'Labi Joshua standing in an art gallery';

const bioParagraphs = about.bioParagraphs?.length
  ? about.bioParagraphs
  : [
      'I am a product designer who loves figuring out how things work and how they are made.',
      'My journey started when I studied Industrial Design at FUTA. There, I learned to build and shape physical objects. In my second year, I discovered digital product design and started playing with how things look and now people use them. I realized that whether I am making a physical tool or a digital app, the same rule applies. The craft matters.',
      'Now, I spend most of my time focusing on the work behind the scenes. I am interested in finding better ways to get things done. I build systems and tools that make my work smooth and easy. My goal is to build systems that help me be more creative.',
      'Outside of work, you can find me watching a funny sitcom or looking at art. I am not a painter, but I have a lot of respect for the hard work and ideas that go into making art. I bring that same respect to my design work. I am always looking for ways to combine solid structure with creative ideas.',
    ];

const stats = about.stats?.length
  ? about.stats
  : [
      { label: 'Based in:',      value: 'Lagos, Nigeria',    sub: 'UTC+1, Always available.' },
      { label: 'Doing this for:', value: '3+ years',          sub: 'A lifetime of making things with my hands.' },
      { label: 'Off the clock:',  value: 'Creative Consumer', sub: 'Obsessed with sitcoms and art history.' },
    ];

const galleryImages = about.galleryImages?.length
  ? about.galleryImages
  : [
      { src: '/images/gallery-desk.jpg',    alt: 'Labi Joshua at his workspace' },
      { src: '/images/gallery-cap.jpg',     alt: 'Labi Joshua' },
      { src: '/images/gallery-street.jpg',  alt: '' },
      { src: '/images/gallery-friends.jpg', alt: '' },
    ];

const outsideDescription = about.outsideDescription
  || 'I keep my downtime creative. You will likely find me getting inspired by shows like Abstract, or tuning into Sticky Notes and The Futur to keep my design mind sharp.';

const outsideThumbnails = about.outsideThumbnails?.length
  ? about.outsideThumbnails
  : [
      { src: '/images/thefutur.jpg',    alt: 'The Futur' },
      { src: '/images/stickynotes.jpg', alt: 'Sticky Notes' },
    ];

const howIWorkDescription = about.howIWorkDescription
  || 'I start by finding the real problem so I can build the best solution. I focus on making systems that are simple and built to last. I always try to improve my work and tools to make things run smoothly. Finally, I stay curious by looking at art and stories to find new ideas for my projects.';

const sayHiDescription = about.sayHiDescription
  || "I'm currently taking on one new project for Q3 2026 — and always happy to swap notes on systems, tokens, or what to lift on a Tuesday. The fastest way is email.";

const email = about.email || 'jospecial34@gmail.com';
const phone = about.phone || '+234 816 9203 595';
---

<Layout
  title="About — Labi Joshua"
  description="I'm a product designer who loves figuring out how things work and how they are made."
>

  <!-- Hero -->
  <section class="about-hero pt-16 pb-16 px-6 text-center max-w-2xl mx-auto">
    <span class="inline-block border border-dashed border-neutral-300 bg-neutral-100 rounded-full px-4 py-1 text-xs tracking-wide mb-6" style="color: rgba(0, 0, 0, 0.5);">
      This is me
    </span>
    <h1 class="font-serif text-5xl md:text-[52px] leading-[1.15] tracking-tight text-neutral-900">
      Welcome to <span style="color: #51782B;">my corner of the Interweb.</span>
    </h1>
  </section>

  <div class="about-content max-w-[1100px] mx-auto px-6">

    <!-- Intro: Photo + Bio -->
    <section class="intro-section mb-16">
      <div class="intro-photo">
        <img
          src={profilePhoto}
          alt={profilePhotoAlt}
          class="w-full h-full object-cover object-top"
          loading="eager"
        />
      </div>
      <div class="intro-bio flex flex-col justify-center gap-4">
        <h2 class="font-serif leading-tight text-neutral-900" style="font-size: 40px;">
          <span style="color: #51782B;">Hi!</span> I'm Labi Joshua.
        </h2>
        <div class="flex flex-col gap-3 text-sm text-neutral-500 leading-relaxed">
          {bioParagraphs.map((para) => <p>{para}</p>)}
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="stats-section mb-16">
      {stats.map((s) => (
        <div class="stat-card">
          <span class="stat-label">{s.label}</span>
          <span class="stat-value">{s.value}</span>
          <span class="stat-sub">{s.sub}</span>
        </div>
      ))}
    </section>

    <!-- Gallery -->
    <section class="gallery-section" style="margin-bottom: 48px;">
      <div class="flex items-center justify-between mb-5">
        <div class="flex items-center gap-2 text-sm text-neutral-600">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          Welcome to my world
        </div>
        <span class="text-sm text-neutral-400">Gallery</span>
      </div>

      <div class="gallery-grid">
        <div class="gallery-large bg-neutral-200">
          <img src={galleryImages[0]?.src} alt={galleryImages[0]?.alt} class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="gallery-mid bg-neutral-300">
          <img src={galleryImages[1]?.src} alt={galleryImages[1]?.alt} class="w-full h-full object-cover" loading="lazy" />
        </div>
        {galleryImages[2] && (
          <div class="gallery-sm bg-neutral-200">
            <img src={galleryImages[2].src} alt={galleryImages[2].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        )}
        {galleryImages[3] && (
          <div class="gallery-sm bg-neutral-300">
            <img src={galleryImages[3].src} alt={galleryImages[3].alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
        )}
      </div>
    </section>

    <!-- Me outside of work -->
    <section class="outside-section" style="margin-bottom: 48px;">
      <h2 class="outside-heading font-serif text-neutral-900">Me outside of work</h2>
      <div class="outside-content">
        <p class="text-sm text-neutral-500 leading-relaxed" style="margin-bottom: 24px;">
          {outsideDescription}
        </p>
        <div class="outside-thumbnails">
          {outsideThumbnails.map((thumb, i) => (
            <div class={`outside-thumb ${i === 0 ? 'bg-blue-700' : 'bg-red-500'}`}>
              <img src={thumb.src} alt={thumb.alt} class="w-full h-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How I work -->
    <section class="two-col-section" style="margin-bottom: 48px;">
      <h2 class="two-col-heading font-serif text-neutral-900">How I work</h2>
      <p class="text-sm text-neutral-500 leading-relaxed">
        {howIWorkDescription}
      </p>
    </section>

    <!-- Say hi -->
    <section class="two-col-section" style="margin-bottom: 48px;">
      <h2 class="two-col-heading font-serif text-neutral-900">Say hi.</h2>
      <div>
        <p class="text-sm text-neutral-500 leading-relaxed" style="margin-bottom: 24px;">
          {sayHiDescription}
        </p>
        <div class="contact-cards">
          <a href={`mailto:${email}`} class="contact-card">
            <span class="contact-label">Email</span>
            <span class="contact-value">{email}</span>
          </a>
          <div class="contact-card">
            <span class="contact-label">Phone number</span>
            <span class="contact-value">{phone}</span>
          </div>
        </div>
      </div>
    </section>

  </div>

</Layout>

<style>
  .about-hero {
    margin-bottom: 64px;
  }
  @media (max-width: 767px) {
    .about-hero {
      display: none;
    }
    .about-content {
      display: flex;
      flex-direction: column;
      padding-top: 48px;
    }
    .intro-section   { order: 1; }
    .gallery-section { order: 2; }
    .stats-section   { order: 3; }
    .outside-section { order: 4; }
    .about-content > section:nth-child(5) { order: 5; }
    .about-content > section:nth-child(6) { order: 6; }
  }

  .contact-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background-color: #F9FAFB;
    border-radius: 16px;
    padding: 12px 20px;
    text-decoration: none;
  }
  .contact-label {
    font-size: 11px;
    color: #A3A3A3;
  }
  .contact-value {
    font-size: 18px;
    font-family: 'Instrument Serif', Georgia, serif;
    color: #51782B;
  }

  .two-col-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .two-col-heading {
    font-size: 44px;
    line-height: 1.15;
  }
  @media (max-width: 767px) {
    .two-col-section { grid-template-columns: 1fr; }
    .two-col-heading { font-size: 36px; }
  }

  .outside-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }
  .outside-heading {
    font-size: 44px;
    line-height: 1.15;
  }
  .outside-thumbnails {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .outside-thumb {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
  }
  .outside-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (max-width: 767px) {
    .outside-section { grid-template-columns: 1fr; }
    .outside-heading { font-size: 36px; }
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 2fr 1.3fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 12px;
    height: 420px;
  }
  .gallery-large {
    grid-row: 1 / 3;
    border-radius: 16px;
    overflow: hidden;
  }
  .gallery-mid {
    grid-row: 1 / 3;
    border-radius: 16px;
    overflow: hidden;
  }
  .gallery-sm {
    border-radius: 16px;
    overflow: hidden;
  }
  @media (max-width: 767px) {
    .gallery-grid {
      grid-template-columns: 2fr 1fr;
      grid-template-rows: 1fr 1fr;
      height: 280px;
    }
    .gallery-mid { display: none; }
  }

  .stats-section {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
  }
  .stat-card {
    background-color: #F9FAFB;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat-label {
    font-size: 12px;
    color: #A3A3A3;
  }
  .stat-value {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 24px;
    color: #51782B;
  }
  .stat-sub {
    display: block;
    font-size: 12px;
    color: #A3A3A3;
    margin-top: 16px;
    text-align: right;
  }
  @media (max-width: 767px) {
    .stats-section {
      grid-template-columns: 1fr;
    }
  }

  .intro-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: stretch;
  }
  .intro-photo {
    border-radius: 24px;
    overflow: hidden;
    background-color: #e5e5e5;
    width: 448px;
    height: 520px;
    flex-shrink: 0;
  }
  .intro-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  @media (max-width: 767px) {
    .intro-section {
      grid-template-columns: 1fr;
    }
    .intro-photo {
      display: none;
    }
  }
</style>
